{
  "name": "chub-media-manager",
  "version": "1.0.0",
  "description": "CHUB — Chodeus' Media Script Hub (React 19 frontend)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json,md}\" && npm run format:utilities",
    "format:utilities": "node scripts/format-utilities.js",
    "stylelint": "stylelint 'src/**/*.css' --fix"
  },
  "dependencies": {
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.24",
    "cron-validator": "^1.4.0",
    "cronstrue": "^3.14.0",
    "prop-types": "15.8.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=18.20.8"
  }
}
